# Python
__pycache__/
*.pyc
*.pyo

# Local Claude config (per-project)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Local-only assets and intermediates
data_raw/
model_edges/results/

# Big regenerable datasets (regenerate with scripts/prepare_*.py)
data/single_omniglot/
data/single_quickdraw/

# Cloned upstream baselines: ignore everything by default,
# then whitelist our own adapters / drivers / docs.
baselines/**
!baselines/PATCHES.md
!baselines/*/
!baselines/*/run_arcset_dataset.py
!baselines/*/run_full.sh

# Author's local PDF
ArcSet_*.pdf
